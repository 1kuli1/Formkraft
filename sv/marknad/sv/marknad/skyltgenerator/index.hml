<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Skyltgenerator för marknadsknallar</title>
  <style>
    /* Grundinställningar för hela sidan */
    * {
      box-sizing: border-box;
    }

    /* Sidans bakgrund och typsnitt */
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #f3f4f6;
      color: #111827;
    }

    /* Huvudlayout med kontrollpanel och skylt */
    .app {
      display: grid;
      grid-template-columns: 380px 1fr;
      gap: 24px;
      min-height: 100vh;
      padding: 24px;
    }

    /* Kontrollpanelen till vänster */
    .panel {
      background: #ffffff;
      border-radius: 18px;
      padding: 20px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    }

    /* Rubrik i kontrollpanelen */
    .panel h1 {
      margin: 0 0 8px;
      font-size: 24px;
    }

    /* Förklarande text */
    .panel p {
      margin: 0 0 18px;
      color: #4b5563;
      line-height: 1.4;
    }

    /* Varje fältgrupp */
    .field {
      margin-bottom: 14px;
    }

    /* Etikett för varje fält */
    label {
      display: block;
      font-weight: bold;
      margin-bottom: 6px;
      font-size: 14px;
    }

    /* Textfält, nummerfält och väljare */
    input, select, textarea {
      width: 100%;
      padding: 11px 12px;
      border: 1px solid #d1d5db;
      border-radius: 10px;
      font-size: 15px;
    }

    /* Textområde */
    textarea {
      min-height: 70px;
      resize: vertical;
    }

    /* Rad med två kolumner */
    .row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }

    /* Knappstil */
    button {
      width: 100%;
      padding: 13px 14px;
      border: none;
      border-radius: 12px;
      background: #111827;
      color: white;
      font-size: 16px;
      font-weight: bold;
      cursor: pointer;
      margin-top: 8px;
    }

    /* Knapp när musen ligger över */
    button:hover {
      opacity: 0.9;
    }

    /* Yta där skylten visas */
    .preview-wrap {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }

    /* Själva skylten */
    .sign {
      width: min(100%, 760px);
      min-height: 520px;
      background: #ffffff;
      color: #111827;
      border-radius: 28px;
      padding: 42px;
      box-shadow: 0 18px 50px rgba(0,0,0,0.18);
      text-align: center;
      border: 10px solid #111827;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    /* Liten övertext */
    .topline {
      font-size: 28px;
      font-weight: bold;
      letter-spacing: 1px;
      text-transform: uppercase;
    }

    /* Produktnamn */
    .product {
      font-size: 72px;
      font-weight: 900;
      line-height: 0.95;
      margin: 22px 0 8px;
      word-break: break-word;
    }

    /* Beskrivning */
    .description {
      font-size: 28px;
      line-height: 1.25;
      margin: 8px auto 18px;
      max-width: 620px;
    }

    /* Prisfält */
    .price {
      font-size: 96px;
      font-weight: 900;
      line-height: 1;
      margin: 8px 0;
    }

    /* Enhet efter pris */
    .unit {
      font-size: 42px;
      font-weight: bold;
    }

    /* Erbjudandebox */
    .offer {
      display: inline-block;
      padding: 12px 22px;
      border-radius: 999px;
      background: #facc15;
      color: #111827;
      font-size: 30px;
      font-weight: 900;
      margin: 16px auto;
    }

    /* Nedersta raden */
    .bottom {
      display: flex;
      justify-content: space-between;
      align-items: end;
      gap: 20px;
      margin-top: 22px;
      font-size: 22px;
      font-weight: bold;
    }

    /* Swishruta */
    .swish {
      text-align: left;
    }

    /* Säljarnamn */
    .seller {
      text-align: right;
    }

    /* Klass för mörkt tema */
    .theme-dark {
      background: #111827;
      color: #ffffff;
      border-color: #facc15;
    }

    /* Klass för grönt tema */
    .theme-green {
      background: #14532d;
      color: #ffffff;
      border-color: #bbf7d0;
    }

    /* Klass för gult tema */
    .theme-yellow {
      background: #facc15;
      color: #111827;
      border-color: #111827;
    }

    /* Anpassning för mobil */
    @media (max-width: 900px) {
      .app {
        grid-template-columns: 1fr;
        padding: 14px;
      }

      .sign {
        min-height: 460px;
        padding: 28px;
      }

      .product {
        font-size: 48px;
      }

      .price {
        font-size: 68px;
      }

      .description {
        font-size: 22px;
      }

      .bottom {
        flex-direction: column;
        align-items: center;
        text-align: center;
      }

      .swish, .seller {
        text-align: center;
      }
    }

    /* Utskriftsläge */
    @media print {
      body {
        background: white;
      }

      .panel {
        display: none;
      }

      .app {
        display: block;
        padding: 0;
      }

      .preview-wrap {
        padding: 0;
      }

      .sign {
        width: 100vw;
        min-height: 100vh;
        border-radius: 0;
        box-shadow: none;
      }
    }
  </style>
</head>
<body>
  <main class="app">
    <section class="panel">
      <h1>Skyltgenerator</h1>
      <p>Fyll i uppgifterna och skapa en tydlig marknadsskylt. Skriv ut skylten eller visa den på mobil, surfplatta eller skärm.</p>

      <div class="field">
        <label for="toplineInput">Övertext</label>
        <input id="toplineInput" type="text" value="Dagens erbjudande">
      </div>

      <div class="field">
        <label for="productInput">Produkt</label>
        <input id="productInput" type="text" value="Nypotatis">
      </div>

      <div class="field">
        <label for="descriptionInput">Beskrivning</label>
        <textarea id="descriptionInput">Lokalt odlad och nyupptagen idag</textarea>
      </div>

      <div class="row">
        <div class="field">
          <label for="priceInput">Pris</label>
          <input id="priceInput" type="text" value="25 kr">
        </div>

        <div class="field">
          <label for="unitInput">Enhet</label>
          <input id="unitInput" type="text" value="/ kg">
        </div>
      </div>

      <div class="field">
        <label for="offerInput">Erbjudande</label>
        <input id="offerInput" type="text" value="3 kg för 65 kr">
      </div>

      <div class="row">
        <div class="field">
          <label for="swishInput">Swish</label>
          <input id="swishInput" type="text" value="123 456 78 90">
        </div>

        <div class="field">
          <label for="sellerInput">Säljare</label>
          <input id="sellerInput" type="text" value="Forsmans gård">
        </div>
      </div>

      <div class="field">
        <label for="themeInput">Tema</label>
        <select id="themeInput">
          <option value="theme-light">Ljust</option>
          <option value="theme-dark">Mörkt/guld</option>
          <option value="theme-green">Grönt</option>
          <option value="theme-yellow">Gult</option>
        </select>
      </div>

      <button onclick="updateSign()">Uppdatera skylt</button>
      <button onclick="window.print()">Skriv ut skylt</button>
    </section>

    <section class="preview-wrap">
      <article id="sign" class="sign">
        <div>
          <div id="toplineText" class="topline">Dagens erbjudande</div>
          <div id="productText" class="product">Nypotatis</div>
          <div id="descriptionText" class="description">Lokalt odlad och nyupptagen idag</div>
          <div>
            <span id="priceText" class="price">25 kr</span>
            <span id="unitText" class="unit">/ kg</span>
          </div>
          <div id="offerText" class="offer">3 kg för 65 kr</div>
        </div>

        <div class="bottom">
          <div id="swishText" class="swish">Swish: 123 456 78 90</div>
          <div id="sellerText" class="seller">Forsmans gård</div>
        </div>
      </article>
    </section>
  </main>

  <script>
    // Funktion som hämtar text från ett inmatningsfält.
    function getValue(id) {
      // Returnerar värdet från fältet med angivet id.
      return document.getElementById(id).value;
    }

    // Funktion som uppdaterar skylten med användarens uppgifter.
    function updateSign() {
      // Hämtar själva skyltelementet.
      const sign = document.getElementById('sign');

      // Hämtar valt tema från rullistan.
      const selectedTheme = getValue('themeInput');

      // Återställer skyltens klassnamn.
      sign.className = 'sign';

      // Lägger till mörkt tema om användaren valt det.
      if (selectedTheme === 'theme-dark') sign.classList.add('theme-dark');

      // Lägger till grönt tema om användaren valt det.
      if (selectedTheme === 'theme-green') sign.classList.add('theme-green');

      // Lägger till gult tema om användaren valt det.
      if (selectedTheme === 'theme-yellow') sign.classList.add('theme-yellow');

      // Uppdaterar övertexten.
      document.getElementById('toplineText').textContent = getValue('toplineInput');

      // Uppdaterar produktnamnet.
      document.getElementById('productText').textContent = getValue('productInput');

      // Uppdaterar beskrivningen.
      document.getElementById('descriptionText').textContent = getValue('descriptionInput');

      // Uppdaterar priset.
      document.getElementById('priceText').textContent = getValue('priceInput');

      // Uppdaterar enheten.
      document.getElementById('unitText').textContent = getValue('unitInput');

      // Uppdaterar erbjudandet.
      document.getElementById('offerText').textContent = getValue('offerInput');

      // Uppdaterar Swish-informationen.
      document.getElementById('swishText').textContent = 'Swish: ' + getValue('swishInput');

      // Uppdaterar säljarens namn.
      document.getElementById('sellerText').textContent = getValue('sellerInput');
    }

    // Uppdaterar skylten när sidan laddas.
    updateSign();
  </script>
</body>
</html>
